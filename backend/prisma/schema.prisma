// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum CandidateStatus {
  PENDING
  PASSED
  INTERVIEWING
  HIRED
  REJECTED
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ParseStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id    String @id
  name  String
  email String @unique
  phone String @unique
}

model Candidate {
  id                  String                @id
  name                String?
  phone               String?
  email               String?
  city                String?
  status              CandidateStatus       @default(PENDING)
  resumeSummary       String?
  highlightedStrengths String?
  highlightedWeaknesses String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  resumeFile          ResumeFile?
  resumeParse         ResumeParse?
  extraction          CandidateExtraction?
  scores              CandidateScore[]
  screeningJobs       ScreeningJob[]
  events              ScreeningEvent[]
}

model ResumeFile {
  id           String    @id
  candidateId  String    @unique
  originalName String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  uploadedAt   DateTime  @default(now())
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model ResumeParse {
  id           String      @id
  candidateId  String      @unique
  pageCount    Int
  rawText      String
  cleanedText  String
  parseStatus  ParseStatus @default(PENDING)
  errorMessage String?
  parsedAt     DateTime?
  candidate    Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateExtraction {
  id             String    @id
  candidateId    String    @unique
  basicInfoJson  String
  educationJson  String
  workExperienceJson String
  skillsJson     String
  projectJson    String
  rawModelOutput String
  correctedJson  String?
  extractedAt    DateTime  @default(now())
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateScore {
  id                  String    @id
  candidateId         String
  jobRequirementId    String?
  jdText              String
  requiredSkillsJson  String
  preferredSkillsJson String
  overallScore        Int
  skillScore          Int
  experienceScore     Int
  educationScore      Int
  aiComment           String
  comparedLabel       String?
  scoredAt            DateTime  @default(now())
  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model ScreeningJob {
  id           String    @id
  candidateId  String
  jdText       String
  requiredSkillsJson String
  preferredSkillsJson String
  status       JobStatus @default(PENDING)
  stage        String
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model ScreeningEvent {
  id          String    @id
  candidateId String
  jobId       String?
  type        String
  stage       String
  payloadJson String
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model JobRequirement {
  id                  String           @id
  title               String
  description         String
  requiredSkillsJson  String
  preferredSkillsJson String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}
